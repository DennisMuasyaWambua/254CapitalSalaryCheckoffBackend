# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - PostgreSQL for both Local and Production
# Local: postgresql://postgres:postgres@localhost:5432/salary_checkoff_db
# Production: postgresql://salary_checkoff_user:your_secure_password@localhost:5432/salary_checkoff_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salary_checkoff_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AWS S3 (Document Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=254capital-documents
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
USE_S3=False

# Africa's Talking (SMS Gateway - Legacy)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_SENDER_ID=254CAPITAL

# Wasiliana (SMS Gateway - Current)
WASILIANA_API_KEY=your-wasiliana-api-key
WASILIANA_SENDER_ID=254-CAPITAL

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Microsoft Azure Email Configuration (Microsoft Graph API)
AZURE_TENANT_ID=your-azure-tenant-id-here
AZURE_CLIENT_ID=your-azure-client-id-here
AZURE_CLIENT_SECRET=your-azure-client-secret-here
SENDER_EMAIL=checkoff@254-capital.com

# OTP Settings
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Application URLs
FRONTEND_URL=http://localhost:3000
