# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-very-strong-secret-key-at-least-50-characters-long
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-ec2-ip

# Docker Settings (used by docker-compose)
DOCKER_IMAGE=your-dockerhub-username/salary-checkoff-backend
DOCKER_TAG=latest

# PostgreSQL Database (Docker container)
DB_USER=salary_checkoff_user
DB_PASSWORD=your-very-strong-database-password
DATABASE_URL=postgresql://salary_checkoff_user:your-very-strong-database-password@db:5432/salary_checkoff_db

# Redis (Docker container)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AWS S3 Configuration
USE_S3=True
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET_NAME=254capital-documents
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# Africa's Talking SMS Gateway
AFRICASTALKING_USERNAME=your-africastalking-username
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_SENDER_ID=254CAPITAL

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@254capital.com

# OTP Settings
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Application URLs
FRONTEND_URL=https://your-frontend-domain.com
